<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- TermuxActivity DayNight NoActionBar theme (night). -->
    <!-- Terminal background stays black in both day and night. -->
    <style name="Theme.TermuxActivity.DayNight.NoActionBar" parent="Theme.TermuxApp.DayNight.NoActionBar">
        <!-- Terminal background is always black. -->
        <item name="android:windowBackground">@color/black</item>

        <!-- Avoid action mode toolbar pushing down terminal content when
             selecting text on pre-6.0 (non-floating toolbar). -->
        <item name="android:windowActionModeOverlay">true</item>

        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>

        <!-- https://developer.android.com/training/tv/start/start.html#transition-color -->
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>

        <!-- Left drawer: use Material 3 surface colors. -->
        <item name="buttonBarButtonStyle">@style/TermuxActivity.Drawer.ButtonBarStyle</item>
        <item name="termuxActivityDrawerBackground">?attr/colorSurface</item>
        <item name="termuxActivityDrawerImageTint">?attr/colorOnSurface</item>

        <!-- Extra keys colors: Material 3 tonal. -->
        <item name="extraKeysButtonTextColor">?attr/colorOnSurface</item>
        <item name="extraKeysButtonActiveTextColor">?attr/colorPrimary</item>
        <item name="extraKeysButtonBackgroundColor">?attr/colorSurface</item>
        <item name="extraKeysButtonActiveBackgroundColor">?attr/colorSurfaceVariant</item>
    </style>

</resources>
